          <AuxValues>
            <AuxValue name="JavaCodeGenerator_AddingCodePost" type="java.lang.String" value="cb_Menu.setRenderer(new DefaultListCellRenderer() {&#xa;            @Override&#xa;            public Component getListCellRendererComponent(JList&lt;?&gt; list, Object value, int index, boolean isSelected, boolean cellHasFocus) {&#xa;                JLabel label = (JLabel) super.getListCellRendererComponent(list, value, index, isSelected, cellHasFocus);&#xa;&#xa;                // T&#xed;nh to&#xe1;n chi&#x1ec1;u r&#x1ed9;ng c&#x1ea7;n thi&#x1ebf;t cho m&#x1ed7;i m&#x1ee5;c d&#x1ef1;a tr&#xea;n n&#x1ed9;i dung&#xa;                FontMetrics metrics = label.getFontMetrics(label.getFont());&#xa;                int width = metrics.stringWidth(value.toString()) + 20; // 20 &#x111;&#x1ec3; c&#xf3; th&#xea;m kho&#x1ea3;ng tr&#x1ed1;ng&#xa;                list.setFixedCellWidth(width);&#xa;                &#xa;                return label;&#xa;            }&#xa;});"/>
            <AuxValue name="JavaCodeGenerator_TypeParameters" type="java.lang.String" value="&lt;String&gt;"/>
          </AuxValues>
